      <luaMethod luaMethodName="checkSum" luaMethodCode="-- Global Scope (Top of your script)&#13;&#10;local has_ffi, ffi = pcall(require, &quot;ffi&quot;)&#13;&#10;local band = bit.band&#13;&#10;&#13;&#10;--[[&#13;&#10;    OPTIMIZED ROLAND CHECKSUM (JD-990)&#13;&#10;    Uses FFI direct memory access via C++ getRawAddress()&#13;&#10;    Performance: ~0.02ms for 32KB&#13;&#10;--]]&#13;&#10;function checkSum(m)&#13;&#10;    local len = m:getSize()&#13;&#10;    local sum = 0&#13;&#10;&#13;&#10;    -- High-speed FFI path&#13;&#10;    if has_ffi and m.getRawAddress then&#13;&#10;        local addr = m:getRawAddress()&#13;&#10;        -- Direct pointer access (Zero C++ overhead per byte)&#13;&#10;        local ptr = ffi.cast(&quot;uint8_t*&quot;, tonumber(addr))&#13;&#10;        &#13;&#10;        for i = 0, len - 1 do&#13;&#10;            sum = sum + ptr[i]&#13;&#10;        end&#13;&#10;    else&#13;&#10;        -- Fallback path for Standard Lua 5.1 / Compatibility&#13;&#10;        local getByte = m.getByte&#13;&#10;        for i = 0, len - 1 do&#13;&#10;            sum = sum + getByte(m, i)&#13;&#10;        end&#13;&#10;    end&#13;&#10;&#13;&#10;    -- Return 7-bit two's complement (Roland standard)&#13;&#10;    return band(-sum, 0x7F)&#13;&#10;end"
                 luaMethodLinkedProperty="" luaMethodSource="0" uuid="4d5c2cafb428400788f2bd32c82ddf0f"
                 luaMethodValid="1"/>
      <luaMethod luaMethodName="profileCheckSum" luaMethodCode="function profileCheckSum()&#13;&#10;    local testSize = 33216&#13;&#10;    local iterations = 500&#13;&#10;    local m = MemoryBlock()&#13;&#10;    m:setSize(testSize, true)&#13;&#10;    &#13;&#10;    -- Fill with data&#13;&#10;    for i=0, testSize-1 do m:setByte(i, i % 128) end&#13;&#10;&#13;&#10;    console(&quot;--- Starting REAL Benchmark ---&quot;)&#13;&#10;    local start = os.clock()&#13;&#10;    &#13;&#10;    local finalVerification = 0&#13;&#10;    for i = 1, iterations do&#13;&#10;        -- We add the result to a variable so the JIT can't delete the call&#13;&#10;        finalVerification = finalVerification + checkSum(m)&#13;&#10;    end&#13;&#10;    &#13;&#10;    local finish = os.clock()&#13;&#10;    local elapsed = finish - start&#13;&#10;&#13;&#10;    -- This print is CRITICAL. It forces the JIT to execute the loop.&#13;&#10;    console(&quot;Checksum verification (to prevent code stripping): &quot; .. finalVerification)&#13;&#10;    &#13;&#10;    console(string.format(&quot;Avg per call: %.4f ms&quot;, (elapsed / iterations) * 1000))&#13;&#10;end"
                 luaMethodLinkedProperty="componentLuaMouseDown" luaMethodSource="0"
                 uuid="c233b2fc702d437c838e54cbce5f4ab3" luaMethodValid="1"/>
