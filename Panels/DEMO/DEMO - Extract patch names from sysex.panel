      <luaMethod luaMethodName="save_file" luaMethodCode="--&#13;&#10;-- Called when a mouse is down on this component&#13;&#10;--&#13;&#10;-- get name of modulator with L(comp:getOwner():getName())&#13;&#10;-- get mouse event info from event parameter event.x, event.y, event.mods, etc.&#13;&#10;-- x coordinate = event.x&#13;&#10;-- y coordinate = event.y&#13;&#10;&#13;&#10;save_file = function(--[[ CtrlrComponent --]] comp --[[ MouseEvent --]], event)&#13;&#10;    fileToWrite = utils.saveFileWindow(&quot;Save 331216 byte embedded file for re-loading&quot;, getLastDir(), &quot;*.syx&quot;, true)&#13;&#10;&#13;&#10;    if fileToWrite:isValid() == false then&#13;&#10;        return&#13;&#10;    end&#13;&#10;&#13;&#10;    -- Let's see if the file exists&#13;&#10;    if fileToWrite:existsAsFile() == false then&#13;&#10;        -- The file is not there, that's ok, let's try to create it&#13;&#10;        if fileToWrite:create() == false then&#13;&#10;            -- Ooooh we can't create it, we need to fail here&#13;&#10;            utils.warnWindow(&quot;File write&quot;, &quot;The destination file does not exist, and i can't create it&quot;)&#13;&#10;&#13;&#10;            return&#13;&#10;        end&#13;&#10;    end&#13;&#10;&#13;&#10;    if sysexData():getSize() &lt;= 0 then&#13;&#10;        utils.warnWindow(&quot;Data to write&quot;, 'Error!')&#13;&#10;       return&#13;&#10;    end&#13;&#10;&#13;&#10;    -- If we reached this point, we have a valid file we can try to write to&#13;&#10;&#13;&#10;    if fileToWrite:replaceWithData(sysexData()) == false then&#13;&#10;        utils.warnWindow(&quot;File write&quot;, &quot;Failed to write data to file: &quot; .. fileToWrite.getFullPathName())&#13;&#10;    end&#13;&#10;end&#13;&#10;"
                 luaMethodLinkedProperty="componentLuaMouseDown" luaMethodSource="0"
                 uuid="00ee8f4f31454daaa3df3ccbf468e6fc" luaMethodValid="1"/>
      <luaMethod luaMethodName="getLastDir" luaMethodCode="getLastDir = function()&#13;&#10;    lad = panel:getLabelComponent(&quot;lastaccesseddir&quot;)&#13;&#10;    if L(lad:getText()) == &quot;&quot; then&#13;&#10;        return File.getSpecialLocation(File.userDesktopDirectory)&#13;&#10;    else&#13;&#10;        return File(lad:getText())&#13;&#10;    end&#13;&#10;end"
                 luaMethodLinkedProperty="" luaMethodSource="0" uuid="07a6f1463bea4f0a841685007013276c"
                 luaMethodValid="1"/>
    </luaManagerMethods>
  </luaManager>
